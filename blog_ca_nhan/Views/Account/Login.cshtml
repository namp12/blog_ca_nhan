@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="feature-card shadow-premium border-0 p-5">
                <div class="text-center mb-4">
                    <h2 class="font-heading display-6">Chào mừng trở lại</h2>
                    <p class="text-muted">Tiếp tục quản lý blog của bạn.</p>
                </div>

                <form asp-action="Login" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger border-0 small">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập</label>
                        <input name="username" type="text" class="form-control form-control-lg rounded-3 fs-6" required placeholder="Tên đăng nhập của bạn">
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between">
                            <label class="form-label fw-bold">Mật khẩu</label>
                            <a href="#" class="small text-muted text-decoration-none">Quên mật khẩu?</a>
                        </div>
                        <input name="password" type="password" class="form-control form-control-lg rounded-3 fs-6" required placeholder="••••••••">
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold fs-5 shadow-sm">Đăng nhập</button>
                    
                    <div class="text-center mt-4">
                        <p class="text-muted small">Chưa có tài khoản? <a asp-action="Register" class="text-primary fw-bold text-decoration-none">Đăng ký ngay</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
