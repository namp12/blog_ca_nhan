@model List<blog_ca_nhan.Models.Category>
@{
    ViewData["Title"] = "Chuyên mục";
    ViewData["ActiveMenu"] = "categories";
    Layout = "_AdminLayout";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">📂 Chuyên mục</h1>
    <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
        + Thêm Chuyên mục
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 rounded-3 mb-4">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 rounded-3 mb-4">@TempData["Error"]</div>
}

<div class="admin-card p-0">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th class="px-4 py-3 fw-semibold text-muted small border-0">TÊN</th>
                <th class="px-3 py-3 fw-semibold text-muted small border-0">SLUG</th>
                <th class="px-3 py-3 fw-semibold text-muted small border-0">MÔ TẢ</th>
                <th class="px-3 py-3 border-0 text-end">HÀNH ĐỘNG</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td class="px-4 py-3 fw-semibold">@cat.Name</td>
                <td class="px-3 py-3 text-muted small">@cat.Slug</td>
                <td class="px-3 py-3 text-muted small">@cat.Description</td>
                <td class="px-3 py-3 text-end">
                    <form asp-action="Delete" method="post" onsubmit="return confirm('Xoá chuyên mục này?')">
                        <input type="hidden" name="id" value="@cat.Id">
                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3">Xoá</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<!-- Add Category Modal -->
<div class="modal fade" id="addCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Thêm Chuyên mục mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body px-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên chuyên mục</label>
                        <input name="name" type="text" class="form-control rounded-3" required placeholder="Du lịch, Công nghệ...">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả (tuỳ chọn)</label>
                        <textarea name="description" class="form-control rounded-3" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>
