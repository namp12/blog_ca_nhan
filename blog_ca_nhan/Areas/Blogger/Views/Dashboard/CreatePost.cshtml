@{
    ViewData["Title"] = "Viết bài mới";
    Layout = "_AdminLayout";
    var blogId = (int)ViewData["BlogId"]!;
}

<div class="admin-page-header">
    <h1 class="admin-page-title">Viết bài mới</h1>
    <a asp-action="Posts" asp-route-blogId="@blogId" class="btn btn-outline-secondary rounded-pill px-4 small">Huỷ</a>
</div>

<form asp-action="CreatePost" method="post">
    <input type="hidden" name="blogId" value="@blogId" />
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="admin-card mb-4">
                <input type="text" name="title" class="form-control form-control-lg border-0 fw-bold fs-4 px-0 mb-3"
                       placeholder="Tiêu đề bài viết..." required style="box-shadow:none; outline:none;">
                <hr>
                <textarea name="content" class="form-control border-0 px-0" rows="20"
                          placeholder="Bắt đầu viết nội dung bài viết của bạn tại đây..." required
                          style="box-shadow:none; resize:none; font-size:1rem; line-height:1.8"></textarea>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="admin-card mb-3">
                <h6 class="fw-bold mb-3">Xuất bản</h6>
                <div class="mb-3">
                    <label class="form-label small fw-semibold text-muted">CHUYÊN MỤC</label>
                    <select name="categoryId" class="form-select rounded-3 small">
                        @foreach (var cat in (List<blog_ca_nhan.Models.Category>)ViewData["Categories"]!)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold text-muted">TÓM TẮT</label>
                    <textarea name="summary" class="form-control rounded-3 small" rows="3"
                              placeholder="Mô tả ngắn gọn bài viết..."></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" name="publish" value="false" class="btn btn-outline-secondary rounded-pill flex-fill fw-semibold small">
                        Lưu nháp
                    </button>
                    <button type="submit" name="publish" value="true" class="btn btn-primary rounded-pill flex-fill fw-semibold small">
                        <i class="fa-solid fa-paper-plane me-1"></i>Xuất bản
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>
